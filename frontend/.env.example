# ── Supabase (recommended for GitHub Pages) ──────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── FastAPI fallback (local dev with backend) ────────────────────────────────
# Set VITE_USE_FASTAPI=true to use the Python backend instead of Supabase
# VITE_USE_FASTAPI=true
# VITE_API_URL=http://127.0.0.1:8000

# GitHub Pages base path (set automatically in CI; use locally only when testing GH Pages builds)
# VITE_BASE_PATH=/carrom-tournament/
